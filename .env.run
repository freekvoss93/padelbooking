# =============================================================================
# Peakz Padel — automated court booking  (template — copy to .env)
# =============================================================================

# ----------------------------------------------------------------------------
# Peakz / FOYS credentials
# ----------------------------------------------------------------------------
PEAKZ_EMAIL=freek_voss@hotmail.com
PEAKZ_PASSWORD=Nijmegen024!

# Peakz federation UUID — used in the OAuth token request.
# Confirmed from live traffic 2026-03-24.
PEAKZ_FEDERATION_ID=df82f4dd-fd87-4af5-9c2f-656fe1a44357

# Location UUID for Peakz Padel Nijmegen Westerpark — used in slot search.
# Confirmed from live traffic 2026-03-24.
PEAKZ_LOCATION_ID=b575a17a-a618-4de7-9127-51a15bff75f1

# Reservation type ID (6 = standard padel court booking).
PEAKZ_RESERVATION_TYPE_ID=6

# Human-readable club name used in notifications and logs
PEAKZ_CLUB_NAME=Peakz Padel Nijmegen Westerpark

# ----------------------------------------------------------------------------
# Booking preferences
# ----------------------------------------------------------------------------
# Preferred start times in order: primary 20:00/19:30/19:00, fallback 18:30/20:30
PREFERRED_TIMES=20:00,19:30,19:00,18:30,20:30

# Only book indoor double courts (type "baan"). Leave blank to accept any court.
COURT_TYPE=baan

DURATION_MINUTES=90
BOOKING_ADVANCE_WEEKS=4

# Skip booking if credit balance is below this amount (EUR)
MIN_CREDIT_BALANCE=20.0

# ----------------------------------------------------------------------------
# Notifications — email via SMTP
# ----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=padelbooking.freek@gmail.com
SMTP_PASSWORD=rqvbaxfaeppmdiwt
SMTP_FROM=padelbooking.freek@gmail.com
NOTIFICATION_TO=freek_voss@hotmail.com

# ----------------------------------------------------------------------------
# Backend selection
# ----------------------------------------------------------------------------
# USE_API=true  → FOYS REST API (recommended now that endpoints are confirmed)
# USE_API=false → Playwright browser automation (fallback)
USE_API=true

FOYS_BASE_URL=https://api.foys.io

# URL for the Playwright fallback
PEAKZ_BOOKING_URL=https://peakzpadel.nl/reserveren

# ----------------------------------------------------------------------------
# Run modes
# ----------------------------------------------------------------------------
DRY_RUN=false
TEST_MODE=true
FORCE_RUN_NOW=true

# One-off scheduled test: TEST_RUN_AT=2026-03-24T10:00:00
TEST_RUN_AT=

# Override target booking date: BOOKING_DATE_OVERRIDE=2026-04-21
BOOKING_DATE_OVERRIDE=

# ----------------------------------------------------------------------------
# Storage
# ----------------------------------------------------------------------------
STATE_DB_PATH=data/state.db
SCREENSHOTS_DIR=data/screenshots
